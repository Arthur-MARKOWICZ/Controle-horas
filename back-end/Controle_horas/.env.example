# Copy to .env and replace placeholders before running locally.
# JWT_SECRET must be a strong random value (>= 32 bytes). Example:
#   openssl rand -base64 32

DB_URL=jdbc:postgresql://localhost:5432/controle_horas
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_32_BYTES
JWT_EXPIRATION_MS=3600000
CORS_ALLOWED_ORIGINS=http://localhost:5173
SERVER_PORT=8080
